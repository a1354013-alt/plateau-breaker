#
# PlateauBreaker backend environment variables (example)
#
# Copy to `.env` at the repository root and load it into your environment, e.g.:
# - Backend dev (from backend/): `uvicorn app.main:app --reload --env-file ../.env`
# - Or export the variables in your shell/session.
#

# Optional. SQLite file path (absolute OR relative to `backend/`).
# Examples:
# - data/plateaubreaker.sqlite3
# - backend/data/plateaubreaker.sqlite3
# - C:/path/to/plateaubreaker.sqlite3
PLATEAUBREAKER_DB_PATH=

# Optional. Defines what "today" means for analytics windows and record validation.
# Default: Asia/Taipei
APP_TIMEZONE=Asia/Taipei

# Optional. Comma-separated allowed origins for CORS.
# Default matches the Vite dev server on localhost.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
