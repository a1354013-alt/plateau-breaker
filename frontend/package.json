{
  "name": "plateaubreaker-web",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "generate:api": "openapi-typescript ./openapi.json -o ./src/generated/api.ts",
    "capture:screenshots": "node ./scripts/capture-screenshots.mjs",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:ci": "vitest run --coverage && node ./scripts/check_coverage.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@primeuix/themes": "^2.0.3",
    "axios": "^1.13.6",
    "chart.js": "^4.5.1",
    "pinia": "^3.0.4",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.4",
    "vue": "^3.5.30",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.19.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.3",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^9.0.0",
    "globals": "^15.0.0",
    "jsdom": "^29.0.2",
    "openapi-typescript": "7.6.1",
    "playwright": "1.59.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.0.0",
    "vite": "^8.0.7",
    "vitest": "^4.1.3",
    "vue-eslint-parser": "^10.0.0",
    "vue-tsc": "^3.2.5"
  }
}
